# Copy to `.env.local` (never commit secrets).

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (optional for fully local demo — catalogue falls back to bundled mock data)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: used by API routes for inserts (newsletter, contact, orders)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (test mode)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email (optional — without RESEND_API_KEY, order emails log to the server console)
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@rokrestbakery.co.uk

# Analytics (optional — enable one)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Postcodes (optional — Ideal Postcodes; demo uses server heuristic in `/api/postcode`)
IDEAL_POSTCODES_API_KEY=
